# Redis connection URL
# For local development with Docker: redis://localhost:6379
# For Upstash: redis://default:YOUR_PASSWORD@YOUR_ENDPOINT.upstash.io:6379
REDIS_URL=redis://localhost:6379

# CoinGecko API key (optional but recommended)
# Get one from https://www.coingecko.com/en/api/pricing
COINGECKO_API_KEY=

# RPC URLs (optional, defaults to public endpoints)
# For better performance and reliability, use your own RPC endpoints
# Free options: Alchemy, Infura, QuickNode, Ankr
RPC_URL_MAINNET=
RPC_URL_OPTIMISM=
RPC_URL_POLYGON=
RPC_URL_FANTOM=
RPC_URL_BASE=
RPC_URL_ARBITRUM=